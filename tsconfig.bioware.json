{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types-bioware",
    "declarationDir": "./dist/types-bioware",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": []
  },
  "include": [
    "src/index.ts",
    "src/bioware/**/*.ts",
    "src/controller/**/*.ts",
    "src/control/**/*.ts",
    "src/controllee/**/*.ts"
  ]
}
